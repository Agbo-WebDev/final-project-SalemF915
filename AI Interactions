Based on MongoDB schema design best practices, here's how to implement per-user data isolation:

## Core Strategy: Add `userId` to Every Document

The best approach is to include `userId` in every document and filter queries by that field. This creates natural data isolation at the database level.

## 1. **Update Your Schema**

Modify your music files collection to include `userId`:

```javascript
{
  _id: ObjectId,
  userId: ObjectId,  // Reference to user
  filename: "string",
  jsonData: {...},
  folderPath: "string",
  uploadedAt: Date,
  // ... other fields
}
```

## 2. **Create Indexes for Performance**

Add an index on `userId` to optimize queries:

```javascript
async function setupIndexes() {
  await dbo.collection('msc').createIndex({ userId: 1 });
  // Compound index if you frequently query by userId + filename
  await dbo.collection('msc').createIndex({ userId: 1, filename: 1 });
}
```

## 3. **Update Your Backend Routes**

Always filter queries by the logged-in user's ID:

```javascript
// Get user's data ONLY
app.get('/api/files', requireAuth, async (req, res) => {
  try {
    const files = await dbo.collection('msc')
      .find({ userId: new ObjectId(req.session.userId) })
      .toArray();
    res.json(files);
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

// Insert file with userId
app.post('/insert', requireAuth, async (req, res) => {
  try {
    const result = await dbo.collection('msc').insertOne({
      userId: new ObjectId(req.session.userId),
      filename: req.body.filename,
      jsonData: req.body.data,
      uploadedAt: new Date()
    });
    res.json({ success: true, insertedId: result.insertedId });
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

// Get specific file (with userId check)
app.get('/api/files/:fileId', requireAuth, async (req, res) => {
  try {
    const file = await dbo.collection('msc').findOne({
      _id: new ObjectId(req.params.fileId),
      userId: new ObjectId(req.session.userId)  // CRITICAL: verify ownership
    });
    
    if (!file) {
      return res.status(404).json({ error: 'File not found' });
    }
    res.json(file);
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

// Delete file (with userId check)
app.delete('/api/files/:fileId', requireAuth, async (req, res) => {
  try {
    const result = await dbo.collection('msc').deleteOne({
      _id: new ObjectId(req.params.fileId),
      userId: new ObjectId(req.session.userId)  // Prevent deletion of others' files
    });
    
    if (result.deletedCount === 0) {
      return res.status(404).json({ error: 'File not found or not authorized' });
    }
    res.json({ success: true });
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

